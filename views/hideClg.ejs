<%-include('./partials/header')%>

<h2 class="text-3xl text-center py-2 px-3">
  Hide Record of Deptt/College
</h2>

<% var cssInputText="border-2 border-gray-400 rounded-lg my-1 px-3 py-2 mx-5 w-96 h-8 bg-gray-100" %>

<% if (message != undefined) { %>
<p class="text-xl text-red-600 text-center"><%=message%></p>
<%}%>
<!-- search clg code for delete deptt / clg record-->
<div class="w-[80%] mx-auto justify-center  bg-blue-200 my-5 flex ">
  <form action="/api/show/hideclg" method="get" class="py-4 flex flex-col justify-center items-center gap-y-3">
    <input type="number" name="clg_code" placeholder="Deptt/College Code" required class="<%=cssInputText%>">
<input type="submit" value="Search" class=" px-3 py-2 cursor-pointer bg-blue-500 w-24 rounded justify-center text-gray-50  ">
</form>
</div>

<% if (data){%>
<div class="w-[80%] mx-auto justify-center   ">
  <form action="/api/show/hideclg" method="post" class="py-5 flex flex-col justify-center rounded-lg items-center  bg-blue-200">
    <div class="grid grid-cols-2 justify-center mt-5  ">

      <input type="number" readonly name="clg_code" placeholder="Deptt/College Code" required class="<%=cssInputText%>" value="<%=data.clg_code%>">
      <input type="text" name="clg_name" disabled placeholder="Deptt/College Name" class="<%=cssInputText%>" value="<%=data.clg_name%>">

     
      <select name="hide" required class="border-2 border-gray-400 rounded-lg my-1 px-3  mx-5  w-96 h-8 bg-gray-100">
      <option value="" disabled selected>--Select Type--</option>
      <option value="yes">Yes</option>
      <option value="no">No</option>
      </select>
      
    </div>  

      <div class="text-gray-50">
      <input type="submit" value="Hide" class=" px-3 py-2 cursor-pointer bg-blue-500 w-24 rounded justify-center  ">
      </div>

      </select>
      
      </div>   

    <div class="text-gray-50">
      <input type="submit" value="Hide" class=" px-3 py-2 cursor-pointer bg-blue-500 w-24 rounded justify-center  ">
    </div>
  </form>
</div>
<%}%>

<%-include('./partials/footer')%>